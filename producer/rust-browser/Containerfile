FROM debian:bookworm-slim@sha256:1def178129dfb5f24db43afbf2fcac04530012e3264ba4ff81c71184e17a9ee4

ARG DEBIAN_SNAPSHOT=20260623T000000Z
ARG CMAKE_VERSION=4.0.3
ARG CMAKE_SHA256=585ae9e013107bc8e7c7c9ce872cbdcbdff569e675b07ef57aacfb88c886faac
ARG NODE_VERSION=24.1.0
ARG NODE_SHA256=76b77c43f97a7c4cf60917e24c5e212faaf8ca664e433759ef98d12f268b6b49

RUN printf '%s\n' \
      "deb [check-valid-until=no] http://snapshot.debian.org/archive/debian/${DEBIAN_SNAPSHOT} bookworm main" \
      > /etc/apt/sources.list \
    && rm -f /etc/apt/sources.list.d/debian.sources \
    && apt-get -o Acquire::Check-Valid-Until=false update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
      ca-certificates \
      curl \
      file \
      g++ \
      gcc \
      git \
      make \
      ninja-build \
      patch \
      perl \
      pkg-config \
      python3 \
      tar \
      xz-utils \
    && rm -rf /var/lib/apt/lists/*

RUN curl -fL --retry 3 \
      "https://github.com/Kitware/CMake/releases/download/v${CMAKE_VERSION}/cmake-${CMAKE_VERSION}-linux-x86_64.tar.gz" \
      -o /tmp/cmake.tar.gz \
    && printf '%s  %s\n' "$CMAKE_SHA256" /tmp/cmake.tar.gz | sha256sum --check --strict \
    && mkdir -p /opt/cmake \
    && tar -xzf /tmp/cmake.tar.gz --strip-components=1 -C /opt/cmake \
    && rm /tmp/cmake.tar.gz

RUN curl -fL --retry 3 \
      "https://nodejs.org/dist/v${NODE_VERSION}/node-v${NODE_VERSION}-linux-x64.tar.xz" \
      -o /tmp/node.tar.xz \
    && printf '%s  %s\n' "$NODE_SHA256" /tmp/node.tar.xz | sha256sum --check --strict \
    && mkdir -p /opt/node \
    && tar -xJf /tmp/node.tar.xz --strip-components=1 -C /opt/node \
    && rm /tmp/node.tar.xz

ENV PATH=/opt/cmake/bin:/opt/node/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ENV WASM_LLVM_RUST_BROWSER_RUNNER=container

WORKDIR /src
ENTRYPOINT ["/bin/bash", "/src/producer/rust-browser/scripts/build.sh"]
