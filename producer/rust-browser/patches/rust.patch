+use std::ffi::OsStr;
+use std::marker::PhantomData;
+use std::ops::Deref;
+
+pub struct Library;
+
+pub struct Symbol<'library, T> {
+    marker: PhantomData<&'library T>,
+}
+
+#[derive(Debug)]
+pub struct Error;
+
+impl std::fmt::Display for Error {
+    fn fmt(&self, formatter: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
+        formatter.write_str("WASI does not support dynamic libraries")
+    }
+}
+
+impl std::error::Error for Error {}
+
+impl Library {
+    pub unsafe fn new<P: AsRef<OsStr>>(_path: P) -> Result<Self, Error> {
+        Err(Error)
+    }
+
+    pub unsafe fn get<T>(&self, _symbol: &[u8]) -> Result<Symbol<'_, T>, Error> {
+        Err(Error)
+    }
+}
+
+impl<T> Symbol<'_, T> {
+    pub unsafe fn try_as_raw_ptr(self) -> Option<*mut std::ffi::c_void> {
+        None
+    }
+}
+
+impl<T> Deref for Symbol<'_, T> {
+    type Target = T;
+
+    fn deref(&self) -> &Self::Target {
+        unreachable!("WASI cannot load dynamic symbols")
+    }
+}
