diff --git a/libloading_shim/src/lib.rs b/libloading_shim/src/lib.rs
new file mode 100644
index 0000000000000000000000000000000000000000..05e936e2fb33dfba9f65099dd1824c8e79c4e056
--- /dev/null
+++ b/libloading_shim/src/lib.rs
@@ -0,0 +1,69 @@
+#[cfg(not(target_os = "wasi"))]
+mod real;
+
+#[cfg(not(target_os = "wasi"))]
+pub use real::*;
+
+#[cfg(target_os = "wasi")]
+mod wasi {
+    pub struct Library;
+
+    pub struct Symbol<T>(std::marker::PhantomData<T>);
+
+    // 1. Forge the os::raw::Symbol module that into_raw() expects to return
+    pub mod os {
+        pub mod raw {
+            pub struct Symbol<T>(pub std::marker::PhantomData<T>);
+            impl<T> std::ops::Deref for Symbol<T> {
+                type Target = T;
+                fn deref(&self) -> &T {
+                    unimplemented!("WASM dummy raw symbol")
+                }
+            }
+        }
+    }
+
+    // 2. Implement the missing method
+    impl<T> Symbol<T> {
+        pub unsafe fn into_raw(self) -> os::raw::Symbol<T> {
+            os::raw::Symbol(std::marker::PhantomData)
+        }
+    }
+
+    // 3. Forge the exact Error enum instead of a basic struct
+    #[derive(Debug)]
+    pub enum Error {
+        // This perfectly matches the pattern: libloading::Error::LoadLibraryExW { .. }
+        LoadLibraryExW { dummy: () },
+        WasiUnsupported,
+    }
+
+    impl std::fmt::Display for Error {
+        fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
+            write!(f, "WASI does not support dynamic libraries")
+        }
+    }
+    impl std::error::Error for Error {}
+
+    impl Library {
+        pub unsafe fn new<P: AsRef<std::ffi::OsStr>>(_path: P) -> Result<Library, Error> {
+            Err(Error::WasiUnsupported)
+        }
+        pub unsafe fn get<T>(&self, _symbol: &[u8]) -> Result<Symbol<T>, Error> {
+            Err(Error::WasiUnsupported)
+        }
+        pub fn close(self) -> Result<(), Error> {
+            Ok(())
+        }
+    }
+
+    impl<T> std::ops::Deref for Symbol<T> {
+        type Target = T;
+        fn deref(&self) -> &T {
+            unimplemented!("WASM dummy symbol")
+        }
+    }
+}
+
+#[cfg(target_os = "wasi")]
+pub use wasi::*;
