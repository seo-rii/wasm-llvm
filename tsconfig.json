{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"lib": ["ES2022", "DOM", "WebWorker"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"allowSyntheticDefaultImports": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"rootDir": ".",
		"outDir": "./dist",
		"types": ["node", "vitest/globals"]
	},
	"include": ["runtime/**/*.ts"]
}
