{
	"name": "@seo-rii/wasm-llvm-swift-runtime",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"description": "Source build, packaging, and verification pipeline for the browser Swift runtime",
	"scripts": {
		"check": "node ./scripts/probe-toolchain.mjs --metadata-only",
		"test": "node --test ./scripts/*.test.mjs",
		"build:browser-compiler": "node ./scripts/build-browser-compiler.mjs",
		"build:wasi-compiler": "node ./scripts/build-wasi-compiler.mjs",
		"build:wasi-frontend": "node ./scripts/build-wasi-frontend.mjs",
		"bootstrap:source": "node ./scripts/bootstrap-source-checkout.mjs",
		"discover:build-outputs": "node ./scripts/discover-build-outputs.mjs",
		"contract": "node ./scripts/runtime-contract.mjs",
		"doctor": "node ./scripts/doctor.mjs",
		"discover:upstream": "node ./scripts/discover-upstream-assets.mjs",
		"package:from-plan": "node ./scripts/package-from-build-plan.mjs",
		"import:runtime": "node ./scripts/import-runtime.mjs",
		"export:runtime": "node ./scripts/export-runtime.mjs",
		"workflow:preflight": "node ./scripts/workflow-preflight.mjs",
		"package:runtime": "node ./scripts/package-runtime.mjs",
		"readiness": "node ./scripts/readiness.mjs",
		"validate:contract": "node ./scripts/runtime-contract-runner.mjs",
		"validate:manifest": "node ./scripts/runtime-manifest.mjs",
		"verify:build-outputs": "node ./scripts/verify-build-outputs.mjs",
		"verify:wasi-frontend": "node ./scripts/verify-wasi-frontend.mjs",
		"fetch:official-sdk": "node ./scripts/fetch-official-sdk.mjs",
		"prepare:raw-runtime": "node ./scripts/prepare-raw-runtime.mjs",
		"probe:toolchain": "node ./scripts/probe-toolchain.mjs",
		"probe:install": "node ./scripts/probe-toolchain.mjs --print-install",
		"run:upstream-baseline": "node ./scripts/run-upstream-baseline.mjs"
	}
}
