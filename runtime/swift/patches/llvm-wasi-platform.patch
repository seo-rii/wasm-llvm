new file mode 100644
--- /dev/null
+++ b/llvm/lib/Support/WASI/ThreadLocal.cpp
@@ -0,0 +1,36 @@
+//===- ThreadLocal.cpp - single-threaded WASI TLS cleanup -----------------===//
+
+#if defined(__wasi__)
+
+#include <cstdlib>
+#include <vector>
+
+namespace {
+struct DestructorEntry {
+  void (*Destructor)(void *);
+  void *Object;
+};
+
+static std::vector<DestructorEntry> *DestructorEntries;
+
+static void runThreadLocalDestructors() {
+  for (auto Entry = DestructorEntries->rbegin();
+       Entry != DestructorEntries->rend(); ++Entry)
+    Entry->Destructor(Entry->Object);
+  delete DestructorEntries;
+  DestructorEntries = nullptr;
+}
+} // namespace
+
+extern "C" int __cxa_thread_atexit(void (*Destructor)(void *), void *Object,
+                                    void *) noexcept {
+  if (!DestructorEntries) {
+    DestructorEntries = new std::vector<DestructorEntry>();
+    if (std::atexit(runThreadLocalDestructors) != 0)
+      return -1;
+  }
+  DestructorEntries->push_back({Destructor, Object});
+  return 0;
+}
+
+#endif
