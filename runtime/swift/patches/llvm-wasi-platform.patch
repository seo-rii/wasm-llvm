@@ -0,0 +1,67 @@
+//===- llvm/Support/WASI/Signals.inc - WASI signal support ----------------===//
+//
+// Part of the LLVM Project, under the Apache License v2.0 with LLVM Exceptions.
+// See https://llvm.org/LICENSE.txt for license information.
+// SPDX-License-Identifier: Apache-2.0 WITH LLVM-exception
+//
+//===----------------------------------------------------------------------===//
+
+#include "llvm/Support/ExitCodes.h"
+
+#include <atomic>
+#include <cstdlib>
+
+using SignalFunction = void (*)();
+
+static std::atomic<SignalFunction> InterruptFunction = nullptr;
+static std::atomic<SignalFunction> InfoSignalFunction = nullptr;
+static std::atomic<SignalFunction> OneShotPipeSignalFunction = nullptr;
+
+static bool findModulesAndOffsets(void **, int, const char **, intptr_t *,
+                                  const char *, StringSaver &) {
+  return false;
+}
+
+static bool printMarkupContext(llvm::raw_ostream &, const char *) {
+  return false;
+}
+
+void llvm::sys::RunInterruptHandlers() {
+  if (SignalFunction Handler = InterruptFunction.exchange(nullptr))
+    Handler();
+}
+
+void llvm::sys::SetInterruptFunction(void (*Handler)()) {
+  InterruptFunction = Handler;
+}
+
+void llvm::sys::SetInfoSignalFunction(void (*Handler)()) {
+  InfoSignalFunction = Handler;
+}
+
+void llvm::sys::SetOneShotPipeSignalFunction(void (*Handler)()) {
+  OneShotPipeSignalFunction = Handler;
+}
+
+void llvm::sys::DefaultOneShotPipeSignalHandler() { std::exit(EX_IOERR); }
+
+bool llvm::sys::RemoveFileOnSignal(StringRef, std::string *) { return false; }
+
+void llvm::sys::DontRemoveFileOnSignal(StringRef) {}
+
+void llvm::sys::AddSignalHandler(sys::SignalHandlerCallback FnPtr,
+                                 void *Cookie) {
+  insertSignalHandler(FnPtr, Cookie);
+}
+
+void llvm::sys::CleanupOnSignal(uintptr_t) { RunSignalHandlers(); }
+
+void llvm::sys::unregisterHandlers() {}
+
+void llvm::sys::PrintStackTrace(raw_ostream &OS, int) {
+  OS << "Stack traces are unavailable on WASI\n";
+}
+
+void llvm::sys::DisableSystemDialogsOnCrash() {}
+
+void llvm::sys::PrintStackTraceOnErrorSignal(StringRef, bool) {}
